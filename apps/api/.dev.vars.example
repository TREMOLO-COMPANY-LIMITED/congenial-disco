# Local (Docker PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/starter
# Staging/Production (Supabase Pooler)
# DATABASE_URL=postgresql://user:password@<supabase-pooler-host>:6543/postgres

# Local (Docker Redis + REST proxy)
UPSTASH_REDIS_REST_URL=http://localhost:8079
UPSTASH_REDIS_REST_TOKEN=local-dev-token
# Staging/Production (Upstash)
# UPSTASH_REDIS_REST_URL=https://<your-upstash-endpoint>.upstash.io
# UPSTASH_REDIS_REST_TOKEN=<your-upstash-token>
BETTER_AUTH_SECRET=your-secret-here
BETTER_AUTH_URL=http://localhost:8787
RESEND_API_KEY=
SENTRY_DSN=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
